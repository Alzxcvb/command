OPENROUTER_API_KEY=your-openrouter-key-here

# Optional: override default CLI binary paths (leave blank to use $PATH)
COMMAND_CLAUDE_BIN=
COMMAND_CODEX_BIN=
COMMAND_OPENCODE_BIN=

# Optional: Ollama endpoint (default: http://localhost:11434)
OLLAMA_HOST=

# Optional: override default local model (default: qwen2.5-coder:3b)
COMMAND_LOCAL_MODEL=
